# Flask
FLASK_DEBUG=true
SECRET_KEY=change-me-to-a-random-string

# App identity (used in Met.no User-Agent header)
WETTER_APP_NAME=Wetter
WETTER_APP_CONTACT=you@example.com
WETTER_REQUEST_TIMEOUT=10

# Database
DATABASE_URI=sqlite:///wetter.db

# Initial admin (required on first run with empty DB)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Password policy
PASSWORD_MIN_LENGTH=12

# Account lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

# Data directories
DATA_DIR=data
ML_MODEL_DIR=data/models

# Ecowitt weather station (optional)
ECOWITT_API_KEY=
ECOWITT_PASSKEY=

# Machine learning
ML_RETRAIN_INTERVAL_HOURS=24

# Alerts
ALERT_CHECK_INTERVAL_MINUTES=5
ALERT_EMAIL_ENABLED=false

# Email / SMTP (required if alerts enabled)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Federation (optional)
FEDERATION_ENABLED=false
FEDERATION_API_KEY=
FEDERATION_SYNC_INTERVAL_MINUTES=60

# Background scheduler
SCHEDULER_ENABLED=false
